<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/honeycomb_tile.xml
     A single honeycomb hex outline used as a repeating tile.
     Place as an ImageView with alpha 0.18 over the cream background. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="64dp"
    android:height="74dp"
    android:viewportWidth="64"
    android:viewportHeight="74">

    <!-- Hex 1: top-left -->
    <path
        android:pathData="M16,2 L30,10 L30,26 L16,34 L2,26 L2,10 Z"
        android:strokeColor="#E09000"
        android:strokeWidth="1.5"
        android:fillColor="#00000000" />

    <!-- Hex 2: top-right -->
    <path
        android:pathData="M48,2 L62,10 L62,26 L48,34 L34,26 L34,10 Z"
        android:strokeColor="#E09000"
        android:strokeWidth="1.5"
        android:fillColor="#00000000" />

    <!-- Hex 3: middle (offset row) -->
    <path
        android:pathData="M32,36 L46,44 L46,60 L32,68 L18,60 L18,44 Z"
        android:strokeColor="#E09000"
        android:strokeWidth="1.5"
        android:fillColor="#00000000" />

</vector>