<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:fillViewport="true"
        android:paddingBottom="80dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ════════════════════════════════════════════
                 PAGE HEADER — cream, matches categories screen
            ════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:paddingTop="52dp"
                android:paddingBottom="18dp"
                android:background="@color/cream">

                <!-- Back button row -->
                <TextView
                    android:id="@+id/tvBack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="← Back"
                    android:textColor="@color/honey"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="20dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="15dp"
                    android:paddingBottom="15dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="New Category"
                    android:textColor="@color/black_deep"
                    android:textSize="32sp"
                    android:fontFamily="@font/fredoka_one" />

            </LinearLayout>

            <!-- ════════════════════════════════════════════
                 BODY
            ════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingBottom="24dp">

                <!-- ── CARD 1: Category Name + Budget Limit ── -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <!-- Section label -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CATEGORY DETAILS"
                            android:textColor="@color/muted_text"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="14dp" />

                        <!-- Category Name Field -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilCategoryName"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="14dp"
                            android:hint="Category name"
                            app:boxBackgroundColor="#FFFFFFFF"
                            app:boxStrokeColor="@color/honey"
                            app:boxStrokeWidth="2dp"
                            app:hintTextColor="@color/muted_text"
                            app:startIconDrawable="@null"
                            app:boxCornerRadiusTopStart="14dp"
                            app:boxCornerRadiusTopEnd="14dp"
                            app:boxCornerRadiusBottomStart="14dp"
                            app:boxCornerRadiusBottomEnd="14dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etCategoryName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textCapWords"
                                android:textColor="@color/black_deep"
                                android:textColorHint="@color/muted_text"
                                android:textSize="15sp"
                                android:fontFamily="sans-serif-medium"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:paddingTop="16dp"
                                android:paddingBottom="16dp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Monthly Budget Limit Field -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilBudgetLimit"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Monthly budget limit (R)"
                            app:boxBackgroundColor="#FFFFFFFF"
                            app:boxStrokeColor="@color/honey"
                            app:boxStrokeWidth="2dp"
                            app:hintTextColor="@color/muted_text"
                            app:boxCornerRadiusTopStart="14dp"
                            app:boxCornerRadiusTopEnd="14dp"
                            app:boxCornerRadiusBottomStart="14dp"
                            app:boxCornerRadiusBottomEnd="14dp"
                            app:prefixText="R "
                            app:prefixTextColor="@color/muted_text">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etBudgetLimit"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:textColor="@color/black_deep"
                                android:textColorHint="@color/muted_text"
                                android:textSize="15sp"
                                android:fontFamily="sans-serif-medium"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:paddingTop="16dp"
                                android:paddingBottom="16dp" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- ── CARD 2: Icon Picker ─────────────────── -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <!-- Section label -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CHOOSE AN ICON"
                            android:textColor="@color/muted_text"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="14dp" />

                        <!-- Selected icon preview -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/input_stroke_bg"
                            android:padding="14dp"
                            android:layout_marginBottom="16dp">

                            <androidx.cardview.widget.CardView
                                android:layout_width="52dp"
                                android:layout_height="52dp"
                                app:cardCornerRadius="16dp"
                                app:cardElevation="0dp"
                                app:cardBackgroundColor="#FFD454">
                                <TextView
                                    android:id="@+id/tvSelectedIcon"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:text="🛒"
                                    android:gravity="center"
                                    android:textSize="26sp" />
                            </androidx.cardview.widget.CardView>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="14dp"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Selected Icon"
                                    android:textColor="@color/muted_text"
                                    android:textSize="11sp"
                                    android:fontFamily="sans-serif-medium" />

                                <TextView
                                    android:id="@+id/tvSelectedIconLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Groceries"
                                    android:textColor="@color/black_deep"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    android:fontFamily="sans-serif-medium"
                                    android:layout_marginTop="2dp" />

                            </LinearLayout>

                        </LinearLayout>

                        <!-- Icon category tabs -->
                        <HorizontalScrollView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:scrollbars="none"
                            android:layout_marginBottom="14dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <!-- Tab: Food (selected) -->
                                <TextView
                                    android:id="@+id/tabFood"
                                    android:layout_width="wrap_content"
                                    android:layout_height="32dp"
                                    android:text="🍔 Food"
                                    android:textColor="@color/black_deep"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:fontFamily="sans-serif-medium"
                                    android:background="@drawable/tab_selected_bg"
                                    android:paddingStart="14dp"
                                    android:paddingEnd="14dp"
                                    android:gravity="center"
                                    android:layout_marginEnd="8dp"
                                    android:clickable="true"
                                    android:focusable="true" />

                                <!-- Tab: Home -->
                                <TextView
                                    android:id="@+id/tabHome"
                                    android:layout_width="wrap_content"
                                    android:layout_height="32dp"
                                    android:text="🏠 Home"
                                    android:textColor="@color/muted_text"
                                    android:textSize="12sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:background="@drawable/tab_unselected_bg"
                                    android:paddingStart="14dp"
                                    android:paddingEnd="14dp"
                                    android:gravity="center"
                                    android:layout_marginEnd="8dp"
                                    android:clickable="true"
                                    android:focusable="true" />

                                <!-- Tab: Transport -->
                                <TextView
                                    android:id="@+id/tabTransport"
                                    android:layout_width="wrap_content"
                                    android:layout_height="32dp"
                                    android:text="🚗 Travel"
                                    android:textColor="@color/muted_text"
                                    android:textSize="12sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:background="@drawable/tab_unselected_bg"
                                    android:paddingStart="14dp"
                                    android:paddingEnd="14dp"
                                    android:gravity="center"
                                    android:layout_marginEnd="8dp"
                                    android:clickable="true"
                                    android:focusable="true" />

                                <!-- Tab: Fun -->
                                <TextView
                                    android:id="@+id/tabFun"
                                    android:layout_width="wrap_content"
                                    android:layout_height="32dp"
                                    android:text="🎉 Fun"
                                    android:textColor="@color/muted_text"
                                    android:textSize="12sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:background="@drawable/tab_unselected_bg"
                                    android:paddingStart="14dp"
                                    android:paddingEnd="14dp"
                                    android:gravity="center"
                                    android:layout_marginEnd="8dp"
                                    android:clickable="true"
                                    android:focusable="true" />

                                <!-- Tab: Health -->
                                <TextView
                                    android:id="@+id/tabHealth"
                                    android:layout_width="wrap_content"
                                    android:layout_height="32dp"
                                    android:text="💊 Health"
                                    android:textColor="@color/muted_text"
                                    android:textSize="12sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:background="@drawable/tab_unselected_bg"
                                    android:paddingStart="14dp"
                                    android:paddingEnd="14dp"
                                    android:gravity="center"
                                    android:layout_marginEnd="8dp"
                                    android:clickable="true"
                                    android:focusable="true" />

                                <!-- Tab: Other -->
                                <TextView
                                    android:id="@+id/tabOther"
                                    android:layout_width="wrap_content"
                                    android:layout_height="32dp"
                                    android:text="✨ Other"
                                    android:textColor="@color/muted_text"
                                    android:textSize="12sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:background="@drawable/tab_unselected_bg"
                                    android:paddingStart="14dp"
                                    android:paddingEnd="14dp"
                                    android:gravity="center"
                                    android:clickable="true"
                                    android:focusable="true" />

                            </LinearLayout>

                        </HorizontalScrollView>

                        <!-- ══ ICON GRID — built dynamically by AddCategoryActivity ══ -->
                        <LinearLayout
                            android:id="@+id/iconGridContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- ── SAVE BUTTON ──────────────────────────── -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveCategory"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Save Category"
                    android:textColor="@color/black_deep"
                    android:textSize="16sp"
                    android:fontFamily="@font/fredoka_one"
                    app:backgroundTint="@color/honey"
                    app:cornerRadius="18dp"
                    app:elevation="4dp"
                    android:layout_marginBottom="12dp" />

                <!-- ── CANCEL BUTTON ─────────────────────────── -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancel"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Cancel"
                    android:textColor="@color/muted_text"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    app:strokeColor="@color/input_stroke"
                    app:strokeWidth="2dp"
                    app:cornerRadius="18dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- ════════════════════════════════════════════════════
         BOTTOM NAV — identical to dashboard / categories
    ════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="@color/white"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:elevation="12dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <androidx.cardview.widget.CardView
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="🏠"
                    android:gravity="center"
                    android:textSize="20sp"/>
            </androidx.cardview.widget.CardView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/muted_text"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navExpenses"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <androidx.cardview.widget.CardView
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="📋"
                    android:gravity="center"
                    android:textSize="20sp"/>
            </androidx.cardview.widget.CardView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Expenses"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/muted_text"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center">
            <androidx.cardview.widget.CardView
                android:id="@+id/fabAddExpense"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/honey"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="+"
                    android:gravity="center"
                    android:textColor="@color/black_deep"
                    android:textSize="30sp"
                    android:fontFamily="sans-serif-black"/>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navGoals"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <androidx.cardview.widget.CardView
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="🎯"
                    android:gravity="center"
                    android:textSize="20sp"/>
            </androidx.cardview.widget.CardView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Goals"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/muted_text"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navBadges"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <androidx.cardview.widget.CardView
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="🏆"
                    android:gravity="center"
                    android:textSize="20sp"/>
            </androidx.cardview.widget.CardView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Badges"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/muted_text"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>