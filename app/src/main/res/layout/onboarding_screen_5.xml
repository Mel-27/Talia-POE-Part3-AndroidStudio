<?xml version="1.0" encoding="utf-8"?>
<!-- BUDGET BEE — Onboarding Mockup Screen 5 of 5: Set Up Your First Budget -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@color/cream"
    android:paddingStart="32dp"
    android:paddingEnd="32dp"
    android:paddingTop="56dp"
    android:paddingBottom="32dp">

    <!-- Top spacer -->
    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Set Up Your First Budget"
        android:textColor="@color/black_deep"
        android:textSize="32sp"
        android:fontFamily="@font/fredoka_one"
        android:gravity="center"
        android:layout_marginBottom="10dp" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Three quick steps and you&#8217;re ready to go."
        android:textColor="@color/muted_text"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:lineSpacingMultiplier="1.45"
        android:layout_marginBottom="28dp" />

    <!-- 3 numbered setup steps -->
    <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="10dp" app:cardCornerRadius="18dp" app:cardElevation="3dp" app:cardBackgroundColor="@color/white">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:padding="18dp">
            <androidx.cardview.widget.CardView android:layout_width="42dp" android:layout_height="42dp"
                app:cardCornerRadius="50dp" app:cardElevation="0dp" app:cardBackgroundColor="@color/honey">
                <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                    android:text="1" android:gravity="center" android:textColor="@color/black_deep"
                    android:textSize="18sp" android:textStyle="bold" android:fontFamily="@font/fredoka_one" />
            </androidx.cardview.widget.CardView>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical" android:layout_marginStart="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Enter your monthly income"
                    android:textColor="@color/black_deep"
                    android:textSize="15sp" android:textStyle="bold" android:fontFamily="sans-serif-medium" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Kept private and stored on-device"
                    android:textColor="@color/muted_text" android:textSize="12sp" android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="10dp" app:cardCornerRadius="18dp" app:cardElevation="3dp" app:cardBackgroundColor="@color/black_deep">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:padding="18dp">
            <androidx.cardview.widget.CardView android:layout_width="42dp" android:layout_height="42dp"
                app:cardCornerRadius="50dp" app:cardElevation="0dp" app:cardBackgroundColor="@color/honey">
                <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                    android:text="2" android:gravity="center" android:textColor="@color/black_deep"
                    android:textSize="18sp" android:textStyle="bold" android:fontFamily="@font/fredoka_one" />
            </androidx.cardview.widget.CardView>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical" android:layout_marginStart="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Pick your categories"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" android:textStyle="bold" android:fontFamily="sans-serif-medium" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Groceries, rent, transport &amp; more — or create your own"
                    android:textColor="#88FFFFFF" android:textSize="12sp" android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="0dp" app:cardCornerRadius="18dp" app:cardElevation="3dp" app:cardBackgroundColor="@color/honey">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:padding="18dp">
            <androidx.cardview.widget.CardView android:layout_width="42dp" android:layout_height="42dp"
                app:cardCornerRadius="50dp" app:cardElevation="0dp" app:cardBackgroundColor="@color/black_deep">
                <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                    android:text="3" android:gravity="center" android:textColor="@color/honey"
                    android:textSize="18sp" android:textStyle="bold" android:fontFamily="@font/fredoka_one" />
            </androidx.cardview.widget.CardView>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical" android:layout_marginStart="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Set limits and go!"
                    android:textColor="@color/black_deep"
                    android:textSize="15sp" android:textStyle="bold" android:fontFamily="sans-serif-medium" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Budget Bee tracks everything from here"
                    android:textColor="#88291A00" android:textSize="12sp" android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

    <!-- Dot indicators: screen 5 active -->
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="18dp">
        <View android:layout_width="8dp" android:layout_height="8dp" android:layout_marginEnd="6dp" android:background="#DDDDDD" />
        <View android:layout_width="8dp" android:layout_height="8dp" android:layout_marginEnd="6dp" android:background="#DDDDDD" />
        <View android:layout_width="8dp" android:layout_height="8dp" android:layout_marginEnd="6dp" android:background="#DDDDDD" />
        <View android:layout_width="8dp" android:layout_height="8dp" android:layout_marginEnd="6dp" android:background="#DDDDDD" />
        <View android:layout_width="28dp" android:layout_height="8dp" android:background="@color/honey_dark" />
    </LinearLayout>

    <!-- Get Started button (final screen) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/btnNext"
        android:layout_width="match_parent" android:layout_height="54dp"
        android:layout_marginBottom="10dp" app:cardCornerRadius="18dp" app:cardElevation="4dp" app:cardBackgroundColor="@color/honey">
        <TextView android:layout_width="match_parent" android:layout_height="match_parent"
            android:text="Get Started"
            android:gravity="center" android:textColor="@color/black_deep"
            android:textSize="16sp" android:textStyle="bold" android:fontFamily="@font/fredoka_one" />
    </androidx.cardview.widget.CardView>

    <!-- Skip hidden on last screen (invisible keeps spacing) -->
    <TextView
        android:id="@+id/btnSkip" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Skip" android:textColor="@color/muted_text" android:textSize="13sp"
        android:fontFamily="sans-serif-medium" android:padding="8dp"
        android:visibility="invisible"
        android:layout_gravity="center_horizontal" />

</LinearLayout>