<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream">

    <!-- =======================================================
         MAIN CONTENT
    ======================================================== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingBottom="90dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- =======================================================
                 TOP BAR
            ======================================================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@color/cream"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <ImageView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:src="@drawable/budgetbee"
                    android:scaleType="fitCenter"
                    android:contentDescription="Budget Bee Logo"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="Budget Bee"
                    android:textColor="@color/black_deep"
                    android:textSize="22sp"
                    android:fontFamily="@font/fredoka_one"/>
            </LinearLayout>

            <!-- =======================================================
                 HEADER
            ======================================================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/dashboard_header_bg"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Budget Goals"
                    android:textColor="@color/cream"
                    android:textSize="28sp"
                    android:fontFamily="@font/fredoka_one"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Set your minimum and maximum monthly budget"
                    android:textColor="#99FFF9EC"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="18dp"/>

                <!-- ===================================================
                     GOALS CARD
                ==================================================== -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Monthly Budget Goals"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/black_deep"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Set your spending range"
                            android:textSize="12sp"
                            android:textColor="@color/muted_text"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="14dp"/>
                        <TextView
                            android:id="@+id/tvMinBudgetDisplay"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Minimum: R0"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/black_deep"
                            android:visibility="gone"
                            android:layout_marginTop="12dp"/>

                        <TextView
                            android:id="@+id/tvMaxBudgetDisplay"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Maximum: R0"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/black_deep"
                            android:visibility="gone"
                            android:layout_marginTop="6dp"/>

                        <EditText
                            android:id="@+id/etMinBudget"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:hint="Minimum Goal (R)"
                            android:inputType="numberDecimal"
                            android:paddingStart="14dp"
                            android:backgroundTint="@color/honey"/>

                        <EditText
                            android:id="@+id/etMaxBudget"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="12dp"
                            android:hint="Maximum Goal (R)"
                            android:inputType="numberDecimal"
                            android:paddingStart="14dp"
                            android:backgroundTint="@color/honey"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnUpdateMonthlyBudget"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:layout_marginTop="16dp"
                            android:text="Save Goals"
                            android:textStyle="bold"
                            android:textColor="@color/black_deep"
                            android:backgroundTint="@color/honey"
                            app:cornerRadius="18dp"/>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- =======================================================
                 CATEGORY GRAPH CARD
            ======================================================== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_margin="16dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFFDF7">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:padding="12dp"
                    android:background="#FFF8E1">

                    <!-- Groceries -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="bottom"
                        android:layout_margin="4dp">

                        <TextView
                            android:id="@+id/barLabelGroceries"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="R0"
                            android:textSize="10sp"
                            android:textColor="#6D4C41"
                            android:gravity="center"
                            android:layout_marginBottom="4dp"/>

                        <View
                            android:id="@+id/barGroceries"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:background="#FFD180"/>
                    </LinearLayout>

                    <!-- Entertainment -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="bottom"
                        android:layout_margin="4dp">

                        <TextView
                            android:id="@+id/barLabelEntertainment"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="R0"
                            android:textSize="10sp"
                            android:textColor="#6D4C41"
                            android:gravity="center"
                            android:layout_marginBottom="4dp"/>

                        <View
                            android:id="@+id/barEntertainment"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:background="#EF9A9A"/>
                    </LinearLayout>

                    <!-- Transport -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="bottom"
                        android:layout_margin="4dp">

                        <TextView
                            android:id="@+id/barLabelTransport"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="R0"
                            android:textSize="10sp"
                            android:textColor="#6D4C41"
                            android:gravity="center"
                            android:layout_marginBottom="4dp"/>

                        <View
                            android:id="@+id/barTransport"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:background="#A5D6A7"/>
                    </LinearLayout>

                    <!-- Food -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="bottom"
                        android:layout_margin="4dp">

                        <TextView
                            android:id="@+id/barLabelFood"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="R0"
                            android:textSize="10sp"
                            android:textColor="#6D4C41"
                            android:gravity="center"
                            android:layout_marginBottom="4dp"/>

                        <View
                            android:id="@+id/barFood"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:background="#FFAB91"/>
                    </LinearLayout>

                    <!-- Health -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="bottom"
                        android:layout_margin="4dp">

                        <TextView
                            android:id="@+id/barLabelHealth"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="R0"
                            android:textSize="10sp"
                            android:textColor="#6D4C41"
                            android:gravity="center"
                            android:layout_marginBottom="4dp"/>

                        <View
                            android:id="@+id/barHealth"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:background="#B0BEC5"/>
                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

    <!-- =======================================================
         BOTTOM NAVIGATION
    ======================================================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="@color/white"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:elevation="12dp"
        android:paddingBottom="8dp">

        <!-- HOME -->
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <androidx.cardview.widget.CardView
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="🏠"
                    android:textSize="20sp"
                    android:gravity="center"/>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/muted_text"/>
        </LinearLayout>

        <!-- EXPENSES -->
        <LinearLayout
            android:id="@+id/navExpenses"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <androidx.cardview.widget.CardView
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="📋"
                    android:textSize="20sp"
                    android:gravity="center"/>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Expenses"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/muted_text"/>
        </LinearLayout>

        <!-- ADD -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center">

            <androidx.cardview.widget.CardView
                android:id="@+id/fabAddExpense"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/honey">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="+"
                    android:textSize="30sp"
                    android:textColor="@color/black_deep"
                    android:gravity="center"/>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- GOALS ACTIVE -->
        <LinearLayout
            android:id="@+id/navGoals"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <androidx.cardview.widget.CardView
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/honey">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="🎯"
                    android:textSize="20sp"
                    android:textColor="@color/black_deep"
                    android:gravity="center"/>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Goals"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/black_deep"/>
        </LinearLayout>

        <!-- BADGES -->
        <LinearLayout
            android:id="@+id/navBadges"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <androidx.cardview.widget.CardView
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="🏆"
                    android:textSize="20sp"
                    android:gravity="center"/>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Badges"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/muted_text"/>
        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>