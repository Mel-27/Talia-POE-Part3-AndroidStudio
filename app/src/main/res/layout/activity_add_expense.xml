<?xml version="1.0" encoding="utf-8"?>
<!--
    ╔══════════════════════════════════════════════════════════════╗
    ║     BUDGET BEE — Add Expense (Matches Design System)        ║
    ║                                                              ║
    ║  • Cream background                                          ║
    ║  • ← Back above Fredoka One title                            ║
    ║  • Honey accents, white cards, 18dp corner radius            ║
    ║  • OutlinedBox fields with honey stroke, no startIconDrawable║
    ║  • Dashed photo upload area                                  ║
    ║  • 🍯 Save Expense honey pill button                         ║
    ║  • No bottom nav (modal flow)                                ║
    ╚══════════════════════════════════════════════════════════════╝
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ════════════════════════════════════════════
                 PAGE HEADER
            ════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:paddingTop="52dp"
                android:paddingBottom="18dp"
                android:background="@color/cream">

                <TextView
                    android:id="@+id/tvBack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="← Back"
                    android:textColor="@color/honey"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="20dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="15dp"
                    android:paddingBottom="15dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add Expense"
                    android:textColor="@color/black_deep"
                    android:textSize="32sp"
                    android:fontFamily="@font/fredoka_one" />

            </LinearLayout>

            <!-- ════════════════════════════════════════════
                 BODY
            ════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingBottom="40dp">

                <!-- ── EXPENSE DETAILS CARD ───────────────────── -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="EXPENSE DETAILS"
                            android:textColor="@color/muted_text"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="14dp" />

                        <!-- Description -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilDescription"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="14dp"
                            app:boxBackgroundColor="#FFFFFFFF"
                            app:boxStrokeColor="@color/honey"
                            app:boxStrokeWidth="2dp"
                            app:hintTextColor="@color/muted_text"
                            app:boxCornerRadiusTopStart="14dp"
                            app:boxCornerRadiusTopEnd="14dp"
                            app:boxCornerRadiusBottomStart="14dp"
                            app:boxCornerRadiusBottomEnd="14dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etDescription"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Description"
                                android:inputType="text"
                                android:textColor="@color/black_deep"
                                android:textColorHint="@color/muted_text"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Amount -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilAmount"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="14dp"
                            app:boxBackgroundColor="#FFFFFFFF"
                            app:boxStrokeColor="@color/honey"
                            app:boxStrokeWidth="2dp"
                            app:hintTextColor="@color/muted_text"
                            app:prefixText="R "
                            app:prefixTextColor="@color/black_deep"
                            app:boxCornerRadiusTopStart="14dp"
                            app:boxCornerRadiusTopEnd="14dp"
                            app:boxCornerRadiusBottomStart="14dp"
                            app:boxCornerRadiusBottomEnd="14dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etAmount"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="0.00"
                                android:inputType="numberDecimal"
                                android:textColor="@color/black_deep"
                                android:textColorHint="@color/muted_text"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Date — tapping opens MaterialDatePicker -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilDate"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="14dp"
                            app:boxBackgroundColor="#FFFFFFFF"
                            app:boxStrokeColor="@color/honey"
                            app:boxStrokeWidth="2dp"
                            app:hintTextColor="@color/muted_text"
                            app:endIconMode="custom"
                            app:endIconDrawable="@android:drawable/ic_menu_my_calendar"
                            app:endIconTint="@color/honey_dark"
                            app:boxCornerRadiusTopStart="14dp"
                            app:boxCornerRadiusTopEnd="14dp"
                            app:boxCornerRadiusBottomStart="14dp"
                            app:boxCornerRadiusBottomEnd="14dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etDate"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Date"
                                android:focusable="false"
                                android:clickable="true"
                                android:textColor="@color/black_deep"
                                android:textColorHint="@color/muted_text"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Start Time Field -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilStartTime"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="14dp"
                            app:boxBackgroundColor="#FFFFFFFF"
                            app:boxStrokeColor="@color/honey"
                            app:boxStrokeWidth="2dp"
                            app:hintTextColor="@color/muted_text"
                            app:endIconMode="custom"
                            app:endIconDrawable="@android:drawable/ic_menu_my_calendar"
                            app:endIconTint="@color/honey_dark"
                            app:boxCornerRadiusTopStart="14dp"
                            app:boxCornerRadiusTopEnd="14dp"
                            app:boxCornerRadiusBottomStart="14dp"
                            app:boxCornerRadiusBottomEnd="14dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etStartTime"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Start Time"
                                android:focusable="false"
                                android:clickable="true"
                                android:textColor="@color/black_deep"
                                android:textColorHint="@color/muted_text"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- End Time Field -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilEndTime"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="14dp"
                            app:boxBackgroundColor="#FFFFFFFF"
                            app:boxStrokeColor="@color/honey"
                            app:boxStrokeWidth="2dp"
                            app:hintTextColor="@color/muted_text"
                            app:endIconMode="none"
                            app:boxCornerRadiusTopStart="14dp"
                            app:boxCornerRadiusTopEnd="14dp"
                            app:boxCornerRadiusBottomStart="14dp"
                            app:boxCornerRadiusBottomEnd="14dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etEndTime"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="End Time"
                                android:focusable="false"
                                android:clickable="true"
                                android:textColor="@color/black_deep"
                                android:textColorHint="@color/muted_text"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Category dropdown -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilCategory"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="14dp">

                            <AutoCompleteTextView
                                android:id="@+id/actvCategory"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="none"
                                android:text="Category"
                                android:textColor="@color/black_deep"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- ── RECEIPT PHOTO CARD ──────────────────────── -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RECEIPT PHOTO"
                            android:textColor="@color/muted_text"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="12dp" />

                        <!-- Photo Action Buttons Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <Button
                                android:id="@+id/btnTakePhoto"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_weight="1"
                                android:text="📷 Take Photo"
                                android:textSize="12sp"
                                android:layout_marginEnd="8dp"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                            <Button
                                android:id="@+id/btnChooseFromGallery"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_weight="1"
                                android:text="🖼️ Gallery"
                                android:textSize="12sp"
                                android:layout_marginStart="8dp"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                        </LinearLayout>

                        <!-- Dashed upload area -->
                        <LinearLayout
                            android:id="@+id/photoUploadArea"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="150dp"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="12dp"
                            android:background="@drawable/dashed_upload_bg"
                            android:clickable="true"
                            android:focusable="true">

                            <!-- Placeholder icon — hidden after photo selected -->
                            <TextView
                                android:id="@+id/tvPhotoPlaceholderIcon"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🖼️"
                                android:textSize="36sp"
                                android:layout_marginBottom="10dp" />

                            <!-- Placeholder title — hidden after photo selected -->
                            <TextView
                                android:id="@+id/tvPhotoPlaceholderTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tap to upload receipt"
                                android:textColor="@color/black_deep"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" />

                            <!-- Placeholder subtitle — hidden after photo selected -->
                            <TextView
                                android:id="@+id/tvPhotoPlaceholderSub"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Select a photo from your gallery"
                                android:textColor="@color/muted_text"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="4dp" />

                            <!-- Receipt image preview — shown after photo selected -->
                            <ImageView
                                android:id="@+id/ivReceiptPreview"
                                android:layout_width="match_parent"
                                android:layout_height="150dp"
                                android:scaleType="centerCrop"
                                android:visibility="gone"
                                android:contentDescription="Receipt photo preview" />

                            <!-- Confirmation label — shown after photo selected -->
                            <TextView
                                android:id="@+id/tvPhotoAttachedLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="✅ Receipt attached — tap to change"
                                android:textColor="@color/honey_dark"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="6dp"
                                android:visibility="gone" />

                        </LinearLayout>

                        <!-- Remove photo button — shown when photo is attached -->
                        <Button
                            android:id="@+id/btnRemovePhoto"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:text="✖ Remove Photo"
                            android:textSize="12sp"
                            android:visibility="gone"
                            android:layout_marginTop="12dp"
                            android:backgroundTint="@color/error_red"
                            style="@style/Widget.MaterialComponents.Button" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- ── ACTION BUTTONS ─────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Cancel — outlined -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCancel"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="10dp"
                        android:text="Cancel"
                        android:textColor="@color/muted_text"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        app:strokeColor="@color/input_stroke"
                        app:strokeWidth="2dp"
                        app:cornerRadius="18dp" />

                    <!-- Save — honey pill -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveExpense"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:text="Save Expense 🍯"
                        android:textColor="@color/black_deep"
                        android:textSize="15sp"
                        android:fontFamily="@font/fredoka_one"
                        app:backgroundTint="@color/honey"
                        app:cornerRadius="18dp"
                        app:elevation="4dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>