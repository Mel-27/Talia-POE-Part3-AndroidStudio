<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Top Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@color/cream"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/budgetbee"
                    android:scaleType="fitCenter"
                    android:contentDescription="Budget Bee Logo"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="Budget Bee"
                    android:textColor="@color/black_deep"
                    android:textSize="22sp"
                    android:fontFamily="@font/fredoka_one"/>
            </LinearLayout>

            <!-- Dark Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/dashboard_header_bg"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:paddingTop="20dp"
                android:paddingBottom="22dp">

                <LinearLayout
                    android:id="@+id/greetingRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <!-- LEFT -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="                   Welcome to
                                                             BudgetBee"
                            android:textColor="#99FFF9EC"
                            android:textSize="20sp"/>

                        <TextView
                            android:id="@+id/tvUserName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/cream"
                            android:textSize="22sp"
                            android:fontFamily="@font/fredoka_one"/>
                    </LinearLayout>

                    <!-- Bell -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnReminders"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:minWidth="48dp"
                        android:minHeight="48dp"
                        android:layout_marginEnd="10dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#33FFFFFF">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="🔔"
                            android:gravity="center"
                            android:textSize="20sp"/>
                    </androidx.cardview.widget.CardView>

                    <!-- Avatar — initial populated from Room -->

                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnAccount"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/honey">

                        <TextView
                            android:id="@+id/tvAvatarInitial"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="👤"
                            android:gravity="center"
                            android:textColor="@color/black_deep"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-black"/>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Balance Card — populated from Room -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/balanceCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/greetingRow"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/honey">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="18dp">

                        <LinearLayout
                            android:id="@+id/balanceLeft"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_toStartOf="@+id/streakCard"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="MONTHLY BUDGET LEFT"
                                android:textColor="#99291A00"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:letterSpacing="0.08"/>

                            <!-- Remaining budget from Room -->
                            <TextView
                                android:id="@+id/tvBalanceAmount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="R 0"
                                android:textColor="@color/black_deep"
                                android:textSize="40sp"
                                android:fontFamily="@font/fredoka_one"/>

                            <!-- Budget subtitle from Room -->
                            <TextView
                                android:id="@+id/tvBalanceSub"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textColor="#88291A00"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <!-- Streak card — populated from Room user streak -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/streakCard"
                            android:layout_width="64dp"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/black_deep">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="10dp">

                                <!-- Streak number from Room -->
                                <TextView
                                    android:id="@+id/tvStreak"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🔥0"
                                    android:textColor="@color/honey"
                                    android:textSize="22sp"
                                    android:fontFamily="@font/fredoka_one"
                                    android:gravity="center"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="day\nstreak"
                                    android:textColor="#99FFF9EC"
                                    android:textSize="9sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:textStyle="bold"
                                    android:gravity="center"
                                    android:letterSpacing="0.05"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>
            </RelativeLayout>

            <!-- Body -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="18dp"
                android:paddingBottom="100dp">

                <!-- Quick Cards: Spent + Saved from Room -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="18dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="@color/white">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="💸"
                                android:textSize="26sp"
                                android:layout_marginBottom="8dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SPENT"
                                android:textColor="@color/muted_text"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:letterSpacing="0.08"/>
                            <!-- Populated from Room ExpenseDao -->
                            <TextView
                                android:id="@+id/tvSpentAmount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="R 0"
                                android:textColor="@color/black_deep"
                                android:textSize="22sp"
                                android:fontFamily="@font/fredoka_one"/>
                            <TextView
                                android:id="@+id/tvSpentSubtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="this month"
                                android:textColor="@color/muted_text"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="@color/white">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🏦"
                                android:textSize="26sp"
                                android:layout_marginBottom="8dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SAVED"
                                android:textColor="@color/muted_text"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:letterSpacing="0.08"/>
                            <!-- Populated from Room BudgetGoalDao -->
                            <TextView
                                android:id="@+id/tvSavedAmount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="R 0"
                                android:textColor="@color/black_deep"
                                android:textSize="22sp"
                                android:fontFamily="@font/fredoka_one"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="↓ on track ✓"
                                android:textColor="@color/success_green"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Budget Progress Card — populated from Room -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="18dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Monthly Budget"
                                android:textColor="@color/black_deep"
                                android:textSize="17sp"
                                android:fontFamily="@font/fredoka_one"/>

                            <!-- Badge updated dynamically -->
                            <TextView
                                android:id="@+id/tvBudgetBadge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="On Track"
                                android:textColor="@color/white"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:background="@drawable/badge_green_bg"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="4dp"
                                android:paddingBottom="4dp"/>
                        </LinearLayout>

                        <!-- Progress filled from Room expense totals -->
                        <ProgressBar
                            android:id="@+id/progressBudget"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="10dp"
                            android:progress="0"
                            android:progressDrawable="@drawable/progress_green"
                            android:indeterminate="false"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp">

                            <!-- Spent label from Room -->
                            <TextView
                                android:id="@+id/tvBudgetSpent"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="R 0 spent"
                                android:textColor="@color/muted_text"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif-medium"
                                android:textStyle="bold"/>

                            <!-- Goal label from Room -->
                            <TextView
                                android:id="@+id/tvBudgetGoal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="R 0 goal"
                                android:textColor="@color/black_deep"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif-medium"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Upcoming Payments — populated from Room ReminderDao -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="18dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Upcoming Payments"
                                android:textColor="@color/black_deep"
                                android:textSize="17sp"
                                android:fontFamily="@font/fredoka_one"/>

                            <TextView
                                android:id="@+id/tvSeeAllReminders"
                                android:layout_width="wrap_content"
                                android:layout_height="48dp"
                                android:minHeight="48dp"
                                android:minWidth="48dp"
                                android:gravity="center"
                                android:text="See All →"
                                android:textColor="@color/honey_dark"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:clickable="true"
                                android:focusable="true"
                                android:paddingHorizontal="12dp"/>
                        </LinearLayout>

                        <!-- Empty state shown when no reminders -->
                        <TextView
                            android:id="@+id/tvNoReminders"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No upcoming payments"
                            android:textColor="@color/muted_text"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"
                            android:visibility="gone"/>

                        <!-- Reminder rows injected here from Room ReminderDao -->
                        <LinearLayout
                            android:id="@+id/upcomingPaymentsContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>



                <!-- Top Spending header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Top Spending"
                        android:textColor="@color/black_deep"
                        android:textSize="18sp"
                        android:fontFamily="@font/fredoka_one"/>

                    <TextView
                        android:id="@+id/tvSeeAllCats"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See All →"
                        android:textColor="@color/honey_dark"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="4dp"/>
                </LinearLayout>

                <!-- Top spending rows injected here from Room ExpenseDao + CategoryDao -->
                <LinearLayout
                    android:id="@+id/topSpendingContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="18dp"/>

                <!-- Recent Transactions header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Recent"
                        android:textColor="@color/black_deep"
                        android:textSize="18sp"
                        android:fontFamily="@font/fredoka_one"/>

                    <TextView
                        android:id="@+id/tvSeeAllTx"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See All →"
                        android:textColor="@color/honey_dark"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="4dp"/>
                </LinearLayout>

                <!-- Recent transaction rows injected here from Room ExpenseDao -->
                <LinearLayout
                    android:id="@+id/recentTransactionsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Nav -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="@color/white"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:elevation="12dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <androidx.cardview.widget.CardView
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFD454">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="🏠"
                    android:gravity="center"
                    android:textSize="20sp"/>
            </androidx.cardview.widget.CardView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/honey_dark"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navExpenses"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <androidx.cardview.widget.CardView
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="📋"
                    android:gravity="center"
                    android:textSize="20sp"/>
            </androidx.cardview.widget.CardView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Expenses"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/muted_text"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center">
            <androidx.cardview.widget.CardView
                android:id="@+id/fabAddExpense"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/honey"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="+"
                    android:gravity="center"
                    android:textColor="@color/black_deep"
                    android:textSize="30sp"
                    android:fontFamily="sans-serif-black"/>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navGoals"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <androidx.cardview.widget.CardView
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="🎯"
                    android:gravity="center"
                    android:textSize="20sp"/>
            </androidx.cardview.widget.CardView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Goals"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/muted_text"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navBadges"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <androidx.cardview.widget.CardView
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="🏆"
                    android:gravity="center"
                    android:textSize="20sp"/>
            </androidx.cardview.widget.CardView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Badges"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/muted_text"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>
