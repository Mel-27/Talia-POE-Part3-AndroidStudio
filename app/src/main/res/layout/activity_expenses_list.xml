<?xml version="1.0" encoding="utf-8"?>
<!--
    BUDGET BEE — Expenses Screen
    Changes in this version:
    • Cream top bar (logo + "Budget Bee") above dark header — matches all other screens
    • Dark header with title row: "Expenses" + subtitle left, "+ Category" honey pill right
    • Stats card (TOTAL | ITEMS | AVG/DAY) inside dark header
    • Filter chips: uniform 34dp height, 12sp, consistent paddingStart/End + marginEnd
    • Added "📅 Date Range" chip (4th chip)
    • Sort row: "Sort:" muted label + two 34dp CardView pills side-by-side
    • Custom date range row hidden by default (visibility=gone)
    • All RECEIPT TextViews are tappable (clickable + focusable + foreground ripple)
    • ADDED: tvFilterRange for displaying current filter period
    • ADDED: tvCategoryBreakdown for displaying category totals
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Cream Top Bar — Logo + App Name ────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@color/cream"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/budgetbee"
                    android:scaleType="fitCenter"
                    android:contentDescription="Budget Bee Logo" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="Budget Bee"
                    android:textColor="@color/black_deep"
                    android:textSize="22sp"
                    android:fontFamily="@font/fredoka_one" />

            </LinearLayout>

            <!-- ── Dark Page Header ───────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="22dp"
                android:background="@drawable/dashboard_header_bg">

                <!-- Title + subtitle -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Expenses"
                    android:textColor="@color/cream"
                    android:textSize="28sp"
                    android:fontFamily="@font/fredoka_one"
                    android:layout_marginBottom="4dp" />

                <!-- Filter range display -->
                <TextView
                    android:id="@+id/tvFilterRange"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="This Month"
                    android:textColor="@color/cream"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="12dp"
                    android:alpha="0.8" />

                <!-- Stats card (honey) inside dark header -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/honey">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TOTAL"
                                android:textColor="#99291A00"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:letterSpacing="0.08" />
                            <TextView
                                android:id="@+id/tvTotalExpenses"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="R0"
                                android:textColor="@color/black_deep"
                                android:textSize="22sp"
                                android:fontFamily="@font/fredoka_one"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="36dp"
                            android:background="#33291A00"
                            android:layout_gravity="center_vertical" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ITEMS"
                                android:textColor="#99291A00"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:letterSpacing="0.08" />
                            <TextView
                                android:id="@+id/tvTotalItems"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/black_deep"
                                android:textSize="22sp"
                                android:fontFamily="@font/fredoka_one"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="36dp"
                            android:background="#33291A00"
                            android:layout_gravity="center_vertical" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="AVG/DAY"
                                android:textColor="#99291A00"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:letterSpacing="0.08" />
                            <TextView
                                android:id="@+id/tvAvgPerDay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="R0"
                                android:textColor="@color/black_deep"
                                android:textSize="22sp"
                                android:fontFamily="@font/fredoka_one"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ════════════════════════════════════════════
                 BODY
            ════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="16dp"
                android:paddingBottom="100dp">

                <!-- ── Date Filter Chips — uniform 48dp height ──────── -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="10dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Active chip -->
                        <TextView
                            android:id="@+id/chipThisMonth"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:minHeight="48dp"
                            android:text="This Month"
                            android:gravity="center"
                            android:textColor="@color/black_deep"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:background="@drawable/tab_active_bg"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:layout_marginEnd="8dp"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/chipLast7"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:minHeight="48dp"
                            android:text="Last 7 Days"
                            android:gravity="center"
                            android:textColor="@color/muted_text"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:background="@drawable/tab_row_bg"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:layout_marginEnd="8dp"
                            android:clickable="true"
                            android:focusable="true"/>

                        <TextView
                            android:id="@+id/chip3Months"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:minHeight="48dp"
                            android:text="3 Months"
                            android:gravity="center"
                            android:textColor="@color/muted_text"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:background="@drawable/tab_row_bg"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:layout_marginEnd="8dp"
                            android:clickable="true"
                            android:focusable="true"/>

                        <!-- Custom Range chip -->
                        <TextView
                            android:id="@+id/chipCustomRange"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:minHeight="48dp"
                            android:text="📅 Custom"
                            android:gravity="center"
                            android:textColor="@color/muted_text"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:background="@drawable/tab_row_bg"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:layout_marginEnd="8dp"
                            android:clickable="true"
                            android:focusable="true"/>

                    </LinearLayout>

                </HorizontalScrollView>

                <!-- ── Always-visible Date Range Row ─────────────────── -->
                <LinearLayout
                    android:id="@+id/dateRangeRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStartDate"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="Start Date"
                        android:textColor="@color/muted_text"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        app:strokeColor="@color/input_stroke"
                        app:strokeWidth="2dp"
                        app:cornerRadius="20dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="→"
                        android:textColor="@color/muted_text"
                        android:textSize="16sp"
                        android:layout_marginEnd="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEndDate"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:minHeight="48dp"
                        android:layout_weight="1"
                        android:text="End Date"
                        android:textColor="@color/muted_text"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        app:strokeColor="@color/input_stroke"
                        app:strokeWidth="2dp"
                        app:cornerRadius="20dp" />

                </LinearLayout>

                <!-- Category Totals Section -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Category Totals"
                    android:textColor="@color/black_deep"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white">

                    <TextView
                        android:id="@+id/tvCategoryBreakdown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="14dp"
                        android:text="No expenses in this period"
                        android:textColor="@color/black_deep"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium" />
                </androidx.cardview.widget.CardView>

                <!--  Category Banner — full-width outlined button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddCategory"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="16dp"
                    android:text="+ Add Expense Category"
                    android:textColor="@color/honey_dark"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.02"
                    app:strokeColor="@color/honey_dark"
                    app:strokeWidth="2dp"
                    app:cornerRadius="14dp" />

                <!-- ── Sort Row — two pills, just above the expense list ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sort:"
                        android:textColor="@color/muted_text"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginEnd="10dp" />

                    <!-- Newest First — active (honey) by default -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnSortDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:minWidth="48dp"
                        android:minHeight="48dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingHorizontal="16dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/honey">
                        <TextView
                            android:id="@+id/tvSortDesc"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="↓ Newest First"
                            android:gravity="center"
                            android:textColor="@color/black_deep"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp" />
                    </androidx.cardview.widget.CardView>

                    <!-- Oldest First — inactive (white) by default -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnSortAsc"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:minWidth="48dp"
                        android:minHeight="48dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingHorizontal="16dp"
                        app:cardCornerRadius="50dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/white">
                        <TextView
                            android:id="@+id/tvSortAsc"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="↑ Oldest First"
                            android:gravity="center"
                            android:textColor="@color/muted_text"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp" />
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

                <!-- ── DATE SECTION: TODAY ─────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TODAY"
                        android:textColor="@color/muted_text"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.1" />
                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/input_stroke"
                        android:layout_marginStart="10dp" />
                </LinearLayout>

                <!-- Dynamic expense cards will be inserted here by Kotlin code -->
                <LinearLayout
                    android:id="@+id/dynamicExpenseContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- Static placeholder cards (hidden, replaced by dynamic content) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardExpense1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:visibility="gone"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardExpense2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardExpense3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardExpense4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:visibility="gone"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- ════════════════════════════════════════════════════
         BOTTOM NAV — Expenses tab active
    ════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="@color/white"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:elevation="12dp"
        android:paddingBottom="8dp">

        <LinearLayout android:id="@+id/navHome"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">
            <androidx.cardview.widget.CardView android:layout_width="44dp" android:layout_height="44dp"
                app:cardCornerRadius="14dp" app:cardElevation="0dp" app:cardBackgroundColor="@android:color/transparent">
                <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                    android:text="🏠" android:gravity="center" android:textSize="20sp"/>
            </androidx.cardview.widget.CardView>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Home" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/muted_text" android:fontFamily="sans-serif-medium" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navExpenses"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">
            <androidx.cardview.widget.CardView android:layout_width="44dp" android:layout_height="44dp"
                app:cardCornerRadius="14dp" app:cardElevation="0dp" app:cardBackgroundColor="#FFD454">
                <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                    android:text="📃" android:gravity="center" android:textSize="20sp"/>
            </androidx.cardview.widget.CardView>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Expenses" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/honey_dark" android:fontFamily="sans-serif-medium" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center">
            <androidx.cardview.widget.CardView android:id="@+id/fabAddExpense"
                android:layout_width="54dp" android:layout_height="54dp" android:layout_marginBottom="10dp"
                app:cardCornerRadius="18dp" app:cardElevation="8dp" app:cardBackgroundColor="@color/honey"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                    android:text="+" android:gravity="center" android:textColor="@color/black_deep"
                    android:textSize="30sp" android:fontFamily="sans-serif-black"/>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <LinearLayout android:id="@+id/navGoals"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">
            <androidx.cardview.widget.CardView android:layout_width="44dp" android:layout_height="44dp"
                app:cardCornerRadius="14dp" app:cardElevation="0dp" app:cardBackgroundColor="@android:color/transparent">
                <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                    android:text="🎯" android:gravity="center" android:textSize="20sp"/>
            </androidx.cardview.widget.CardView>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Goals" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/muted_text" android:fontFamily="sans-serif-medium" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navBadges"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">
            <androidx.cardview.widget.CardView android:layout_width="44dp" android:layout_height="44dp"
                app:cardCornerRadius="14dp" app:cardElevation="0dp" app:cardBackgroundColor="@android:color/transparent">
                <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                    android:text="🏆" android:gravity="center" android:textSize="20sp"/>
            </androidx.cardview.widget.CardView>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Badges" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/muted_text" android:fontFamily="sans-serif-medium" android:layout_marginTop="2dp"/>
        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>