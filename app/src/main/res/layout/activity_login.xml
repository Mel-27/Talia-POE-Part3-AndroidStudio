<?xml version="1.0" encoding="utf-8"?>


<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/cream">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:background="@color/honey"
            android:paddingTop="36dp"
            android:paddingBottom="36dp">

            <!-- Honeycomb texture overlay — reuse your budgetbeebackground
                 drawable at very low alpha so it just hints at the pattern -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/budgetbeebackground"
                android:scaleType="centerCrop"
                android:alpha="0.07"
                android:layout_alignParentTop="true"
                android:contentDescription="@null" />

            <!-- Logo — replace bee emoji with vector drawable -->
            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="130dp"
                android:layout_height="130dp"
                android:layout_centerHorizontal="true"
                android:layout_alignParentTop="true"
                android:layout_marginTop="8dp"
                android:src="@drawable/budgetbee"
                android:scaleType="fitCenter"
                android:contentDescription="Budget Bee Logo" />

            <!-- "Welcome Back!" — Fredoka One, matches mockup login-title -->
            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_below="@id/ivLogo"
                android:layout_marginTop="4dp"
                android:text="Welcome Back!"
                android:textColor="@color/black_deep"
                android:textSize="32sp"
                android:fontFamily="@font/fredoka_one"
                android:letterSpacing="0.01" />

            <!-- Tagline — matches mockup login-sub -->
            <TextView
                android:id="@+id/tvTagline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_below="@id/tvWelcome"
                android:layout_marginTop="4dp"
                android:text="Your hive is waiting for you"
                android:textColor="@color/charcoal"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:alpha="0.7" />

        </RelativeLayout>

        <!-- ════════════════════════════════════════════════════
             BOTTOM CARD — Cream white, rounded top corners
             Overlaps the header slightly (negative marginTop)
             Matches mockup login-body structure exactly
        ════════════════════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-28dp"
            app:cardCornerRadius="30dp"
            app:cardElevation="20dp"
            app:cardBackgroundColor="@color/cream">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="32dp"
                android:paddingBottom="40dp">

                <!-- ── Log In / Sign Up Tab Switcher ─────────────
                     Matches mockup tab-row exactly:
                     Pill container (#EDE4C8) with white active pill
                     Wire up in Kotlin: tabLogin/tabSignUp OnClickListener
                     to toggle visibility of fields -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:background="@drawable/tab_row_bg"
                    android:padding="4dp"
                    android:layout_marginBottom="28dp">

                    <!-- Active: Log In tab -->
                    <TextView
                        android:id="@+id/tabLogin"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:minHeight="48dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Log In"
                        android:textColor="@color/black_deep"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:background="@drawable/tab_active_bg"
                        android:clickable="true"
                        android:focusable="true"/>

                    <!-- Inactive: Sign Up tab -->
                    <TextView
                        android:id="@+id/tabSignUp"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:minHeight="48dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Sign Up"
                        android:textColor="@color/muted_text"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:clickable="true"
                        android:focusable="true"/>

                </LinearLayout>

                <!-- ── USERNAME FIELD ──────────────────────────────
                     Uppercase label above + clean outlined box below
                     NO startIconDrawable → zero emoji overlap issue -->

                <!-- Field label — matches mockup input-label style -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="USERNAME OR EMAIL"
                    android:textColor="@color/muted_text"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilUsername"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:boxBackgroundColor="#FFFFFFFF"
                    app:boxStrokeColor="@color/honey"
                    app:boxStrokeWidth="2dp"
                    app:hintTextColor="@color/muted_text"
                    app:boxCornerRadiusTopStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusBottomEnd="14dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etUsername"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="bee@example.com"
                        android:inputType="textEmailAddress"
                        android:imeOptions="actionNext"
                        android:textColor="@color/black_deep"
                        android:textColorHint="@color/muted_text"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- ── PASSWORD FIELD ──────────────────────────────
                     endIconMode gives the eye toggle — no startIcon overlap -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PASSWORD"
                    android:textColor="@color/muted_text"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPassword"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    app:endIconMode="password_toggle"
                    app:endIconTint="@color/honey"
                    app:boxBackgroundColor="#FFFFFFFF"
                    app:boxStrokeColor="@color/honey"
                    app:boxStrokeWidth="2dp"
                    app:hintTextColor="@color/muted_text"
                    app:boxCornerRadiusTopStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusBottomEnd="14dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Enter your password"
                        android:inputType="textPassword"
                        android:imeOptions="actionDone"
                        android:textColor="@color/black_deep"
                        android:textColorHint="@color/muted_text"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Forgot password — right-aligned, matches mockup .forgot -->
                <TextView
                    android:id="@+id/tvForgotPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:minWidth="48dp"
                    android:layout_gravity="end"
                    android:layout_marginBottom="24dp"
                    android:text="Forgot password?"
                    android:textColor="@color/honey_dark"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="12dp"/>

                <!-- ── LOG IN BUTTON ────────────────────────────────
                     Honey yellow, pill shape, Fredoka One font
                     Matches mockup .btn-primary exactly -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="20dp"
                    android:text="🍯  Log In"
                    android:textColor="@color/black_deep"
                    android:textSize="17sp"
                    android:fontFamily="@font/fredoka_one"
                    android:letterSpacing="0.03"
                    app:backgroundTint="@color/honey"
                    app:cornerRadius="28dp"
                    app:elevation="4dp"
                    app:rippleColor="#402D2416" />





                <!-- ── 🐝 Divider ────────────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/input_stroke" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  🐝  "
                        android:textSize="16sp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/input_stroke" />

                </LinearLayout>

                <!-- ── REGISTER LINK ────────────────────────────────
                     Matches mockup .signup-link -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Don't have an account? "
                        android:textColor="@color/muted_text"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tvRegister"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sign Up"
                        android:textColor="@color/honey_dark"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="4dp" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>

    <!--
    ═══════════════════════════════════════════════════════════════════
     DRAWABLE FILES — create these in res/drawable/
    ═══════════════════════════════════════════════════════════════════

    ── 1. res/drawable/tab_row_bg.xml ──────────────────────────────
    <?xml version="1.0" encoding="utf-8"?>
    <shape xmlns:android="http://schemas.android.com/apk/res/android"
        android:shape="rectangle">
        <solid android:color="#EDE4C8" />
        <corners android:radius="50dp" />
    </shape>

    ── 2. res/drawable/tab_active_bg.xml ───────────────────────────
    <?xml version="1.0" encoding="utf-8"?>
    <shape xmlns:android="http://schemas.android.com/apk/res/android"
        android:shape="rectangle">
        <solid android:color="#FFFFFF" />
        <corners android:radius="50dp" />
        <padding android:top="6dp" android:bottom="6dp"
                 android:left="8dp" android:right="8dp" />
    </shape>

    ═══════════════════════════════════════════════════════════════════
     KOTLIN WIRING — LoginActivity.kt
    ═══════════════════════════════════════════════════════════════════

    // Tab switching
    tabLogin.setOnClickListener {
        tabLogin.setBackgroundResource(R.drawable.tab_active_bg)
        tabLogin.setTextColor(getColor(R.color.black_deep))
        tabSignUp.background = null
        tabSignUp.setTextColor(getColor(R.color.muted_text))
        // show login fields, hide signup-only fields
    }
    tabSignUp.setOnClickListener {
        tabSignUp.setBackgroundResource(R.drawable.tab_active_bg)
        tabSignUp.setTextColor(getColor(R.color.black_deep))
        tabLogin.background = null
        tabLogin.setTextColor(getColor(R.color.muted_text))
        // show signup fields
    }

    // Login button
    btnLogin.setOnClickListener {
        val username = etUsername.text.toString().trim()
        val password = etPassword.text.toString().trim()
        if (username.isEmpty()) {
            tilUsername.error = "Username is required"
            return@setOnClickListener
        }
        if (password.isEmpty()) {
            tilPassword.error = "Password is required"
            return@setOnClickListener
        }
        // proceed with Firebase Auth or local DB check
    }

    // Register link
    tvRegister.setOnClickListener {
        tabSignUp.performClick()
    }

    // Forgot password
    tvForgotPassword.setOnClickListener {
        // show a dialog or navigate to ForgotPasswordActivity
    }
    ═══════════════════════════════════════════════════════════════════
    -->